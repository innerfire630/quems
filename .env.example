# =============================================================================
# Smart Queue Management System — Environment Variables (Template)
# =============================================================================
# Copy this file to `.env` and replace the placeholders with real values.
# Never commit `.env` to version control.

# Database (Prisma datasource) — SQLite for development
DATABASE_URL="file:./dev.db"

# NextAuth.js v5 — JWT signing secret (use `openssl rand -base64 32` to generate)
NEXTAUTH_SECRET="change-me-in-production-please-use-a-32-byte-random-string"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# Application environment identifier
APP_ENV="development"

# Refresh token expiry in days (default: 7)
REFRESH_TOKEN_EXPIRY_DAYS="7"
