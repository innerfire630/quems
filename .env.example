# =============================================================================
# .env.example — Smart Queue Management System
# =============================================================================
# Copy this file to .env and adjust the values for your environment.
# NEVER commit real secrets to this file — it contains PLACEHOLDERS only.
# =============================================================================

# ---- Database ----
# Development: SQLite file path
DATABASE_URL="file:./dev.db"
# Production: PostgreSQL connection string
# DATABASE_URL="postgresql://user:password@host:5432/database?schema=public&connection_limit=30&connect_timeout=10&application_name=quems-app"
# Optional: Direct connection for migrations (bypasses connection pooler)
# DIRECT_URL="postgresql://user:password@host:5432/database?schema=public"

# ---- Authentication ----
# Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET="development-secret-do-not-use-in-production"
# Development URL
NEXTAUTH_URL="http://localhost:3000"
# Production URL (must be HTTPS for secure cookies)
# NEXTAUTH_URL="https://queue.example.com"

# ---- Push Notifications (Firebase Cloud Messaging) ----
# Required in production; optional in development (falls back to console-log mode)
# FCM_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"my-project",...}'
# FCM_PROJECT_ID="my-firebase-project"

# ---- CORS ----
# Comma-separated list of allowed mobile app origins (optional)
# ALLOWED_MOBILE_ORIGINS="https://app.example.com,https://admin.example.com"

# ---- Application ----
# IANA timezone for business date display (e.g., Asia/Colombo)
# APP_TIMEZONE="UTC"
NODE_ENV="development"

# ---- Optional Hardening ----
# Rate limiting enabled (default: true in production, false in development)
# RATE_LIMIT_ENABLED="false"
# Maximum request body size in bytes (default: 10485760 = 10 MB)
# MAX_REQUEST_BODY_SIZE="10485760"
# Enable Prisma query logging (default: true in development, false in production)
# PRISMA_LOG_QUERIES="true"

# ---- Optional Database Pool (PostgreSQL only) ----
# Connection pool size (default: 90 for single instance, 30 for 3 instances)
# DATABASE_POOL_SIZE="30"
# Connection timeout in milliseconds (default: 10000)
# DATABASE_CONNECT_TIMEOUT_MS="10000"
