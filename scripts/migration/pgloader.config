LOAD DATABASE
  FROM sqlite://prisma/dev.db
  INTO postgresql://${DATABASE_URL}

WITH
  -- Include all tables except Prisma's internal migration tracking
  -- (prisma migrate deploy handles this table)
  include no drop, create tables, create indexes, reset sequences,
  workers = 4,
  batch size = 2500 rows,
  batch concurrency = 1,
  max parallel create index = 4

-- Schema mapping rules: SQLite types to PostgreSQL types
CAST
  -- Booleans: SQLite stores 0/1, PostgreSQL uses true/false
  type integer to boolean when (= precision 1)
    using (case when integer = 1 then true else false end),

  -- DateTimes: SQLite stores as text/real, PostgreSQL uses timestamp with time zone
  type decimal to timestamptz
    using (to_timestamp(decimal)),

  -- JSON fields: SQLite stores as text, PostgreSQL uses jsonb
  type text to jsonb
    using (text::jsonb),

  -- Integer columns that might use bigint (e.g., audit log IDs)
  type integer to bigint,

  -- Default text-to-text (no transform needed)
  type text to text,

  -- Blobs (not used in current schema, documented for future)
  type blob to bytea;

-- Tables in migration order (respecting foreign keys)
-- System tables
INCLUDING ONLY TABLE NAMES MATCHING
  ~/Role|Permission|RolePermission|UserRole|SystemSetting|AuditLog/

-- Queue domain tables
INCLUDING ONLY TABLE NAMES MATCHING
  ~/Service|Counter|CounterService|CounterOfficer|CounterStatusEvent/

-- Ticket domain tables
INCLUDING ONLY TABLE NAMES MATCHING
  ~/Ticket|TicketEvent|QueueDailySnapshot/

-- Auth tables
INCLUDING ONLY TABLE NAMES MATCHING
  ~/User|RefreshToken|Account|Session|VerificationToken/

-- Display & Kiosk tables
INCLUDING ONLY TABLE NAMES MATCHING
  ~/DisplayBoard|KioskConfig/

-- Notification tables
INCLUDING ONLY TABLE NAMES MATCHING
  ~/DeviceToken|Notification|NotificationReply|BroadcastMessage/

-- Exclude Prisma's internal migrations table
EXCLUDING TABLE NAMES MATCHING
  ~/_prisma_migrations/;
